resource XPGUINewFormeDialogWidget (kXPGUINewFormeDialogResourceID + index_enUS)
{
	__FILE__,
	__LINE__,
	kXPGUINewFormeDialogWidgetID, // WidgetID
	kPMRsrcID_None, // RsrcID
	kBindNone, // Binding
	// Resource ships at the EXPANDED height (with the validation report
	// area shown). When ValidateSelectionForCarton passes, InitializeDialogFields
	// hides the validation widget and shrinks the dialog back to 225px tall
	// (compact targets are absolute — see XPGUIXRailNewFormeDialogController).
