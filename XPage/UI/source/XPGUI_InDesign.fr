{
};

type XPGUIDisplayImagePanelWidget(kViewRsrcType) : GenericPanelWidget(ClassID = kXPGUIDisplayImagePanelWidgetBoss)
{
};

// Same layout as XPGUIDisplayImagePanelWidget, but its boss carries a drag
// source — used for the Photos liées preview so it can be dragged like the
// list rows.
