	kTrue, // Visible
	kTrue, // Enabled
	kTrue, // Erase background
	kInterfacePaletteFill, // Erase to color
	kFalse, // Draw dropshadow
	kXPGUIArticlePanelTitleKey, // Panel name
	{
		// "Not connected" placeholder widgets. Hidden at runtime once the user
		// is logged in; in return all other children of the panel are hidden
		// while the user is logged out. Visibility is toggled by the panel
		// observer on login state changes.
		StaticTextWidget
		(
			kXPGUILoginPromptTextWidgetID, // WidgetId
			kSysStaticTextPMRsrcId, // RsrcId
			kBindNone,
			Frame(20, 40, 380, 100) // left, top, right, bottom
			kFalse, // Visible (will be shown by observer if not logged in)
			kTrue,  // Enabled
			kAlignCenter,
			kEllipsizeEnd,
			kTrue,
			kXPGUILoginPromptTextKey, // Text
