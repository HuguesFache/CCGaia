resource XPGUIImageNodeWidget (kXPGUIImageNodeWidgetRsrcID + index_enUS) 
{ 
	__FILE__, 
	__LINE__, 
	kXPGUIImageNodeWidgetId, 
	kPMRsrcID_None, // WidgetId, RsrcId
	kBindLeft | kBindRight, // Frame binding
	Frame(0,0,387,20) // Frame (left, top, right, bottom)
	kTrue, 
	kTrue, // Visible, Enabled
	"", // Panel name
	{
		// Drop down arrow
		TreeExpanderWidget 
		( 
			kTreeNodeExpanderWidgetID, // WidgetId
			kTreeBranchCollapsedRsrcID, // RsrcId for collapsed node icon
			kApplicationRsrcPluginID, // RsrcPlugin for collapsed node icon
			kBindLeft, // Frame binding
			Frame(2,4,18,18) // Frame
			kTrue, 
			kTrue, // Visible, Enabled
			kTreeBranchExpandedRsrcID, // RsrcId for expanded node icon
			kApplicationRsrcPluginID, // RsrcPlugin for expanded node icon
			kTrue, // Cmd-Click expands/collapses children
			kFalse, // Scroll to show children when expanded
			kIconNoCentering, 
			kIconRaisedLook, // Sets the icon look -- (kIconRaisedLook | kIconFlushLook)
			kFalse,  // Bool integer sets whether the icon draws a well.
		),
		// First column: small colour swatch (12×12) reflecting the photo's
		// "etatimage" attribute from OBJRART.xml. Painted at runtime by the
		// widget mgr from the etatsimages list cached on IXPGPreferences.
		// Square, not round — the SDK has no built-in round swatch.
		// Enabled (kTrue) so it receives mouse events: a click opens the
		// "change état" dialog (handled by kXPGUIImageEtatSwatchEHImpl on
		// kXPGUIImageEtatSwatchWidgetBoss).
		XPGUIImageEtatSwatchWidget
		(
			kXPGUIImageEtatSwatchWidgetID,
			kPMRsrcID_None,
			kBindNone,
			Frame(20,3,32,17)
			kTrue,
			kTrue,
		),
		InfoStaticTextWidget
		(
			kXPGUIImageNameWidgetID, // WidgetId
			kPMRsrcID_None, // RsrcId
			kBindLeft | kBindRight, // Frame binding
			// Trimmed on the right to make room for the placed-status icon
			// then the two action icons.
			Frame(34,0,316,18) // Frame
			kTrue,
			kTrue, // Visible, Enabled
			kAlignLeft, // Alignment
			kEllipsizeEnd, // Ellipsize style — long photo names are truncated.
			kTrue,
			"", // Text Control Data
			0, // WidgetId for associated control for shortcut focus
			kPaletteWindowSystemScriptFontId,
			kPaletteWindowSystemScriptFontId,
		),
		// Placed-status indicator: green check shown when the image is
		// already placed in a frame of the front document. Hidden otherwise.
		// Non-clickable IconSuiteWidget — the look matches the action
		// icons but it doesn't trigger anything on click.
		IconSuiteWidget
		(
			kXPGUIImagePlacedIconWidgetID,
			kPMRsrcID_None,
			kBindRight,
			Frame(320,1,340,19) // Frame (20×18, just before the action icons)
			kTrue,
			kFalse, // Disabled — visual indicator only.
			kIconCentering,
			kIconFlushLook,
			kFalse,
			0,
		),
		// Goto link: clicking selects & scrolls to the linked photo frame
		// in the document layout. Reuses the icon InDesign's own Links panel
		// uses for its "Atteindre le lien" button.
		RollOverIconButtonWidget
		(
			kXPGUIImageGotoLinkBtnWidgetID,         // WidgetId
			kIDLinksUIGotoLinkButtonIconResID,      // Icon RsrcId (LinksUI)
			kLinksUIPluginID,                       // Plug-in that owns it
			kBindRight,                             // Frame binding
			Frame(343,1,363,19)                     // Frame (width 20, height 18)
			kTrue,                                  // Visible
			kTrue,                                  // Enabled
			kADBEIconSuiteButtonType,               // Button type
		),
		// Edit original: clicking opens the high-res image with the OS
		// default app. Reuses the same icon as InDesign's Links panel
		// "Modifier l'original" button.
		RollOverIconButtonWidget
		(
			kXPGUIImageEditOriginalBtnWidgetID,
			kIDLinksUIEditOriginalButtonIconResID,
			kLinksUIPluginID,
			kBindRight,
			Frame(366,1,386,19)
			kTrue,
			kTrue,
			kADBEIconSuiteButtonType,
		),
	}
}

