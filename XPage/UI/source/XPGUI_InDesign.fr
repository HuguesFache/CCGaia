	kTrue,
	kTrue, // Visible, Enabled
	kXPGUINewFormeDialogTitleKey, // Dialog name
	{
		StaticTextWidget 
		( 
			0, 
			kSysStaticTextPMRsrcId, // WidgetId, RsrcId
			kBindNone, 
			Frame(10,10,120,27) // Frame left, top, right, bottom
			kTrue, 
			kTrue, 
			kAlignLeft, // Visible, Enabled, Alignment
			kEllipsizeEnd, 
			kTrue,
			kXPGUIFormeNameKey, 
			0,  // WidgetID this shortcut is connected to, 0 if none.
		),
		TextEditBoxWidget 
		( 
			kXPGUIFormeNameWidgetID, 
			kSysEditBoxPMRsrcId, // WidgetId, RsrcId
			kBindNone, 
			Frame(130, 10, 390, 30) // Frame
			kTrue, 
			kTrue, // Visible, Enabled
			0, // widget id of nudge button
			0, 
			0, // small/large nudge amount
			0, // max num chars( 0 = no limit)
			kFalse, // is read only
			kFalse, // should notify each key stroke
			kFalse, // range checking enabled
			kFalse, // blank entry allowed
			0, 
			0, // upper/lower bounds
			"",  // initial text
		),
		StaticTextWidget 
		( 
			0, 
			kSysStaticTextPMRsrcId, // WidgetId, RsrcId
			kBindNone, 
			Frame(10, 40, 110, 57) // Frame left, top, right, bottom
			kTrue, 
			kTrue, 
			kAlignLeft, // Visible, Enabled, Alignment
			kEllipsizeEnd, 
			kTrue,
			kXPGUIClasseurTextKey, 
			0,  // WidgetID this shortcut is connected to, 0 if none.
		),
		XPGUIDropDownListWidget 
		( 
			kXPGUIRubriqueListWidgetID, 
			kSysDropDownPMRsrcId, // WidgetId, RsrcId
			kBindLeft | kBindRight, // Frame binding
			Frame(120, 40, 390, 60) // Frame (l,t,r,b)
			kTrue, 
			kTrue, // Visible, Enabled
			{
				{				// List Items
				}
			},
		),
        // "Carton photo" — tags the carton being created as a photo-carton
        // (used later to add images to other cartons). Persisted as the
        // isPhotoCarton attribute on the FORME element of the descriptif XML.
        // Sits on the left, where Fixed Content used to live.
        CheckBoxWidget
        (
            kXPGUICartonPhotoWidgetID, // WidgetId
            kSysCheckBoxPMRsrcId, // RsrcId
            kBindTop | kBindLeft,
            Frame(15, 75, 155, 92) // Frame
            kTrue, // Visible
            kTrue, // Enabled
            kAlignLeft, // Alignment
            kXPGUICartonPhotoKey, // Initial text
        ),
		GenericPanelWithBorderWidget 
		( 
			0, // widget ID
			kPMRsrcID_None, // PMRsrc ID
			kBindAll, // frame binding
			Frame(10,105,420,157) //  left, top, right, bottom
			kTrue, // visible
			kTrue, // enabled
			"", 
			{				
				DropDownListWidget
				(
					kXPGUIPhotoListWidgetID,
					kSysDropDownPMRsrcId, // WidgetId, RsrcId
					kBindLeft | kBindTop, // Frame binding
					Frame(5, 18, 85, 35) // Frame (l,t,r,b)
					kTrue,
					kTrue, // Visible, Enabled
					{
						{				// List Items
						}
					},
				),
				// Position dropdown : shows the current slot of the photo
				// selected in the photo dropdown. Changing it triggers a
				// move-with-shift (insert semantic) — the selected photo
				// goes to the new slot, the photos in between shift by 1.
				// The observer rewrites IFormeData::photoIndex on every
				// frame impacted so adornment numbering stays in sync.
				DropDownListWidget
				(
					kXPGUIPhotoPositionListWidgetID,
					kSysDropDownPMRsrcId,
					kBindLeft | kBindTop,
					Frame(90, 18, 175, 35)
					kTrue,
					kTrue,
					{
						{				// List Items
						}
					},
				),
				// Crédit / Légende : checking the box defines the link
				// using the currently-selected text frame, unchecking
				// clears the link. Validation lives in the observer's
				// HandleUseCreditLegendStateChanged.
				CheckBoxWidget
				(
					kXPGUICreditPhotoWidgetID, // WidgetId
					kSysCheckBoxPMRsrcId, // RsrcId
					kBindTop | kBindLeft,
					Frame(180, 18, 240, 35) // Frame
					kTrue, // Visible
					kTrue, // Enabled
					kAlignLeft, // Alignment
					kXPGUICreditKey,  // Initial text
				),
				IconSuiteWidget
				(
					kXPGUIStatusCreditPhotoWidgetID, // widget ID
					kXPGUIOKIconResourceID,
					kXPGUIPluginID,					 // icon, plugin ID
					kBindLeft | kBindBottom,		 // frame binding
					Frame(245, 17, 257, 34)			 //  left, top, right, bottom
					kTrue,							 // visible
					kTrue,							 // enabled
					kADBEIconSuiteButtonType,
					0,
				),
				CheckBoxWidget
				(
					kXPGUILegendPhotoWidgetID,		// WidgetId
					kSysCheckBoxPMRsrcId,			// RsrcId
					kBindTop | kBindLeft,
					Frame(265, 18, 340, 35)
					kTrue,							// Visible
					kTrue,							// Enabled
					kAlignLeft,						// Alignment
					kXPGUILegendKey,				// Initial text
				),
				IconSuiteWidget
				(
					kXPGUIStatusLegendPhotoWidgetID, // widget ID
					kXPGUIKOIconResourceID,
					kXPGUIPluginID, 				 // icon, plugin ID
					kBindLeft | kBindBottom, 		 // frame binding
					Frame(345, 17, 357, 34) 		 //  left, top, right, bottom
					kTrue, 							 // visible
					kTrue, 							 // enabled
					kADBEIconSuiteButtonType,
					0,
				),
			} 
		),
        // "Contenu Fixe" — flags the selected frames whose content stays in
        // place when the carton is reused. Sits below the légende/crédit
        // panel, on the left.
        CheckBoxWidget
        (
            kXPGUIFixedContentWidgetID, // WidgetId
            kSysCheckBoxPMRsrcId, // RsrcId
            kBindTop | kBindLeft,
            Frame(15, 165, 155, 182) // Frame
            kTrue, // Visible
            kTrue, // Enabled
            kAlignLeft, // Alignment
            kXPGUIkFixedContentKey,  // Initial text
        ),
		// Pre-flight style validation report. Filled in by
		// InitializeDialogFields from XPageUIUtils::ValidateSelectionForCarton —
		// hidden when validation passes, in which case the controller shifts
		// the buttons up and shrinks the dialog frame back to compact height.
		StaticMultiLineTextWidget
		(
			kXPGUIValidationMessageWidgetID,
			kPMRsrcID_None,
			kBindNone, // Frame binding
			Frame(10, 190, 420, 270) // Frame
			kTrue,
			kTrue,
			kAlignLeft,
			kEllipsizeEnd,
			kTrue,
			0, // fScrollBarWidgetID
			kPaletteWindowSystemScriptFontId,
			2, // fNumPixelsBetweenLines
			5,
			2, // Insets
			"",
		),
		DefaultButtonWidget
		(
			kOKButtonWidgetID, // WidgetID
			kSysButtonPMRsrcId, // RsrcID
			kBindNone, // Binding
			Frame(105,280,185,300) // Frame (l,t,r,b)
			kTrue,
			kTrue, // Visible, Enabled
			kSDKDefOKButtonApplicationKey,  // Button text
		),
		CancelButtonWidget
		(
			kCancelButton_WidgetID, // WidgetID
			kSysButtonPMRsrcId, // RsrcID
			kBindNone, // Binding
			Frame(195,280,275,300) // Frame (l,t,r,b)
			kTrue,
			kTrue, // Visible, Enabled
			kSDKDefCancelButtonApplicationKey, // Button name
			kFalse,  // Change to Reset on option-click.
		),
	}
};
