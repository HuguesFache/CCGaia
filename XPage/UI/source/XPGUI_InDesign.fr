resource PanelList ((kSDKDefPanelResourceID))
{
	{

		// 1st panel in the list
		kXPGUIFormesPanelResourceID,	// Resource ID for this panel (use SDK default rsrc ID)
		kXPGUIPluginID,			// ID of plug-in that owns this panel
		kIsResizable,
		kXPGUIFormesPanelWidgetActionID,	// Action ID to show/hide the panel
		"",							// Empty panelName + non-empty altMenu below = entry only in the alt path (IPanelMgr.h::RegisterPanel docs).
		"Main:&Window:&Gaia:&XDA " kXPGUIVersion,	// Window > Gaia > XDA … (full path required; the "Submenu:Name" comment in PanelList.fh is misleading).
		0.0,
		0,0,								// Rsrc ID, Plugin ID for a PNG icon resource to use for this palette
		c_Panel,
				
		// 2nd panel in the list
		kXPGUIArticlePanelResourceID,	// Resource ID for this panel (use SDK default rsrc ID)
		kXPGUIPluginID,			// ID of plug-in that owns this panel
		kIsResizable,			// Seule la liste articles grandit ; tout le reste est ancré top/bottom (cf. XPGUIArticlePanelWidget).
		kXPGUIArticlePanelWidgetActionID,	// Action ID to show/hide the panel
		"",							// See XDA panel above.
		"Main:&Window:&Gaia:&XPage",	// Window > Gaia > XPage
		0.0,
		0,0,								// Rsrc ID, Plugin ID for a PNG icon resource to use for this palette
		c_Panel,

		// 3rd panel in the list — Photos liées
		kXPGUIXRailImagesPanelResourceID,	// Resource ID for this panel (use SDK default rsrc ID)
		kXPGUIPluginID,			// ID of plug-in that owns this panel
		kIsResizable,			// User asked for resize parity with XDA / Assemblages.
		kXPGUIImagesPanelWidgetActionID,	// Action ID to show/hide the panel
		"",							// See XDA panel above.
		"Main:&Window:&Gaia:&Photos liées " kXPGUIVersion,	// Window > Gaia > Photos liées …
		0.0,
		0,0,
		c_Panel,
		
		
		// 6th panel in the list — Assemblages mirrors the Formes/XDA palette
		// in layout and behaviour, so it's also resizable.
		kXPGUIAssemblagesPanelResourceID,	// Resource ID for this panel (use SDK default rsrc ID)
		kXPGUIPluginID,			// ID of plug-in that owns this panel
		kIsResizable,
		kXPGUIAssemblagesPanelActionID,	// Action ID to show/hide the panel
		"",							// See XDA panel above.
		"Main:&Window:&Gaia:&Assemblages",	// Window > Gaia > Assemblages
		0.0,
		0,0,
		c_Panel,


	}
};

