/*  Type definition.
*/
type XPGUIXRailImagesPanelWidget(kViewRsrcType) : GenericPalettePanelWidget (ClassID = kXPGUIXRailImagesPanelWidgetBoss)
{
	SizePanelDetailController;
}

/*
// Panel definition.
// This view is not localized: therefore, it can reside here.
// However, if you wish to localize it, it is recommended to
// locate it in one of the localized framework resource files
// (i.e. BscSlDlg_enUS.fr etc.) and update your Panel
// LocaleIndex accordingly.
*/
resource XPGUIXRailImagesPanelWidget (kXPGUIXRailImagesPanelResourceID + index_enUS)
{
	__FILE__,
	__LINE__,
	kXPGUIXRailImagesPanelWidgetID, // WidgetId
	kPMRsrcID_None, // RsrcId
	kBindNone, // Frame binding
	// Layout : zone preview/list (haut), case à cocher "Voir toutes les
	// photos" + refresh, 3 lignes labels+inputs (centre), numéro courant
	// en bas. Hauteur naturelle 600 (ex 300) — borne max de redim. Tous
	// les widgets ancrés en bas et le bord bas du tree + preview ont été
	// décalés de +300 pour préserver le layout à l'ouverture.
	Frame(0,0,529,600) // Frame
	kTrue,
	kTrue, // Enabled
	kTrue, // Erase background
	kInterfacePaletteFill, // Erase to color
	kFalse, // Draw dropshadow
	kXPGUIImagesPanelTitleKey, // Panel name
	{
		// "Not connected" placeholder widgets, toggled by the panel observer.
		StaticTextWidget
		(
			kXPGUILoginPromptTextWidgetID, // WidgetId
			kSysStaticTextPMRsrcId, // RsrcId
			kBindNone,
			Frame(20, 60, 500, 120) // left, top, right, bottom
			kFalse, // Visible (shown by observer when not logged in)
			kTrue,
			kAlignCenter,
			kEllipsizeEnd,
			kTrue,
			kXPGUILoginPromptTextKey,
			0,
		),
		ButtonWidget
		(
			kXPGUILoginPromptButtonWidgetID, // WidgetId
			kSysButtonPMRsrcId, // RsrcId
			kBindNone,
			Frame(200, 135, 320, 160) // left, top, right, bottom
			kFalse, // Visible (shown by observer when not logged in)
			kTrue,
			kXPGUILoginPromptButtonKey,
		),
		StaticTextWidget
		(
			// Shown when the user is logged in but no Gaia/XRail page is
			// active in the front document.
			kXPGUINoGaiaPageTextWidgetID,
			kSysStaticTextPMRsrcId,
			kBindNone,
			Frame(20, 90, 500, 150)
			kFalse,
			kTrue,
			kAlignCenter,
			kEllipsizeEnd,
			kTrue,
			kXPGUINoGaiaPageTextKey,
			0,
		),

		XPGUIXRailDnDDisplayImagePanelWidget
		(
			kXPGUIDisplayImagePanelWidgetID, // WidgetId
			kPMRsrcID_None, // RsrcId
			// Image preview swallows the extra horizontal space when the
			// palette is resized — the list on the left keeps its fixed
			// width, the preview grows to the right.
			kBindAll,
			Frame(400,10,525,450) // Frame
			kTrue, // Visible
			kTrue, // Enabled
			"",
			{
			}
		),
		// "Index / Type / Apply" row (kXPGUIImageIndexWidgetID,
		// kXPGUIImageChangeTypeWidgetID, kXPGUIImageChangeIndexWidgetID,
		// kXPGUIImageChangeIndexBtnWidgetID) was removed at user request —
		// the surface area below Légende/Crédit is now blank. Widget IDs
		// stay declared in case the feature is ever revived.
		SeparatorWidget
		(
			0, // WidgetId
			kPMRsrcID_None, // RsrcId
			kBindLeft | kBindRight | kBindBottom,
			Frame(-1,563,536,564) // Frame (just above the numéro line)
			kFalse,
			kFalse,  // Visible, Enabled
		),
		InfoStaticTextWidget
		(
			kXPGUICurrentNumeroWidgetID,
			kPMRsrcID_None, // WidgetId, RsrcId
			kBindRight | kBindBottom, // Frame binding
			Frame(304,570,520,590) // Frame
			kTrue,
			kTrue,
			kAlignRight,
			kEllipsizeEnd, // Visible, Enabled
			kTrue,
			"", // Text
			0,
			kDialogWindowSystemScriptFontId,
			kDialogWindowSystemScriptHiliteFontId,
		),
		// "Voir toutes les photos" — when ticked, the panel observer
		// stops filtering on the selected frame's article and walks every
		// OBJRART referenced by an assignment in the front document.
		// Refresh icon next door forces a re-scan without changing the
		// state (e.g. after Gaia pushed updates server-side).
		CheckBoxWidget
		(
			kXPGUIShowAllImagesCheckboxWidgetID,
			kSysCheckBoxPMRsrcId,
			kBindBottom | kBindLeft,
			Frame(4, 455, 250, 475)
			kTrue,
			kTrue,
			kAlignLeft,
			kXPGUIShowAllImagesKey,
		),
		RollOverIconButtonWidget
		(
			kXPGUIRefreshImagesBtnWidgetID,
			kIDLinksUIUpdateLinkButtonIconRsrcID,
			kLinksUIPluginID,
			kBindBottom | kBindLeft,
			Frame(255, 455, 275, 475)
			kTrue,
			kTrue,
			kADBEIconSuiteButtonType,
		),
		// Crédit / Légende / Commentaire : labels élargis (4..95) et inputs
		// élargis & rehaussés (100..290, 20px de haut). Tous bottom-anchored
		// pour rester collés en bas si l'utilisateur redimensionne.
		StaticTextWidget
		(
			kXPGUICreditLabelWidgetID, // The Identifier for this Widget
			kSysStaticTextPMRsrcId, // The Plugin ID
			kBindBottom | kBindLeft, // Frame binding
			Frame(4,480,95,500)
			kTrue, // Is this visible
			kTrue, // Is this enabled
			kAlignLeft, // The alignment of this field
			kEllipsizeEnd, // Where to ellipsize the string if the size is larger than its frame
			kTrue,
			kXPGUICreditKey, // The String value
			0,  // The Widget ID for associated control for shortcut focus
		),
		StaticTextWidget
		(
			kXPGUILegendeLabelWidgetID, // The Identifier for this Widget
			kSysStaticTextPMRsrcId, // The Plugin ID
			kBindBottom | kBindLeft, // Frame binding
			Frame(4,505,95,525)
			kTrue, // Is this visible
			kTrue, // Is this enabled
			kAlignLeft, // The alignment of this field
			kEllipsizeEnd, // Where to ellipsize the string if the size is larger than its frame
			kTrue,
			kXPGUILegendKey, // The String value
			0,  // The Widget ID for associated control for shortcut focus
		),
		// Crédit edit box — right edge pulled in 42px to leave room for
		// the two action icons (copy + send) anchored to the right.
		TextEditBoxWidget
		(
			kXPGUICreditTextWidgetID, // The Identifier for this Widget
			kSysEditBoxPMRsrcId, // The Plugin ID
			// kBindRight added so the input stretches with the palette.
			kBindBottom | kBindLeft | kBindRight, // Frame binding
			Frame(100,480,478,500)
			kTrue, // Is this visible
			kTrue, // Is this enabled
			0, // The WidgetID for the nudge button
			0, // A small nudge amount
			0, // A large nudge amount
			0, // The maximum number of characters
			kTrue, // integer readOnly value (display only — sourced from OBJRART)
			kFalse, // Notify on key stroke
			kFalse, // Enable range checking
			kFalse, // Allow blank entry
			0, // The upper limit
			0, // The lower limit
			"",  // The String value
		),
		// Copy crédit → puts the field's text on the OS clipboard.
		// Native InDesign icon (same source as the XDA palette + / trash).
		RollOverIconButtonWidget
		(
			kXPGUICopyCreditBtnWidgetID,
			kContextCopyIconResID,
			kApplicationRsrcPluginID,
			kBindRight | kBindBottom,
			Frame(481, 480, 501, 500)
			kTrue,
			kTrue,
			kADBEIconSuiteButtonType,
		),
		// Send crédit → writes the field into the selected image's
		// kCredit frame on the page. The "paste" glyph reads naturally
		// here: clipboard-paste and "apply text into target frame" are
		// the same gesture from the user's POV.
		RollOverIconButtonWidget
		(
			kXPGUISendCreditBtnWidgetID,
			kContextPasteIconResID,
			kApplicationRsrcPluginID,
			kBindRight | kBindBottom,
			Frame(503, 480, 523, 500)
			kTrue,
			kTrue,
			kADBEIconSuiteButtonType,
		),
		// Légende edit box — same right-edge trim as Crédit.
		TextEditBoxWidget
		(
			kXPGUILegendeTextWidgetID, // The Identifier for this Widget
			kSysEditBoxPMRsrcId, // The Plugin ID
			kBindBottom | kBindLeft | kBindRight, // Frame binding
			Frame(100,505,478,525)
			kTrue, // Is this visible
			kTrue, // Is this enabled
			0, // The WidgetID for the nudge button
			0, // A small nudge amount
			0, // A large nudge amount
			0, // The maximum number of characters
			kTrue, // integer readOnly value (display only — sourced from OBJRART)
			kFalse, // Notify on key stroke
			kFalse, // Enable range checking
			kFalse, // Allow blank entry
			0, // The upper limit
			0, // The lower limit
			"",  // The String value
		),
		// Copy légende → puts the field's text on the OS clipboard.
		RollOverIconButtonWidget
		(
			kXPGUICopyLegendBtnWidgetID,
			kContextCopyIconResID,
			kApplicationRsrcPluginID,
			kBindRight | kBindBottom,
			Frame(481, 505, 501, 525)
			kTrue,
			kTrue,
			kADBEIconSuiteButtonType,
		),
		// Send légende → writes the field into the selected image's
		// kLegend frame on the page.
		RollOverIconButtonWidget
		(
			kXPGUISendLegendBtnWidgetID,
			kContextPasteIconResID,
			kApplicationRsrcPluginID,
			kBindRight | kBindBottom,
			Frame(503, 505, 523, 525)
			kTrue,
			kTrue,
			kADBEIconSuiteButtonType,
		),
		// Commentaire — read-only display sourced from <Commentaire> in
		// the article's OBJRART.xml.
		StaticTextWidget
		(
			kXPGUICommentLabelWidgetID, // The Identifier for this Widget
			kSysStaticTextPMRsrcId, // The Plugin ID
			kBindBottom | kBindLeft, // Frame binding
			Frame(4,530,95,550)
			kTrue, // Is this visible
			kTrue, // Is this enabled
			kAlignLeft, // The alignment of this field
			kEllipsizeEnd, // Where to ellipsize the string if the size is larger than its frame
			kTrue,
			kXPGUICommentLabelKey, // The String value
			0,  // The Widget ID for associated control for shortcut focus
		),
		TextEditBoxWidget
		(
