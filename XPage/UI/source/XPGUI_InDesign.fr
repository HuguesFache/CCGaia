{
	__FILE__,
	__LINE__,
	kXPGUIArticlePanelWidgetID, // WidgetId
	kPMRsrcID_None, // RsrcId
	kBindNone, // Frame binding
	// Hauteur naturelle 600 (ex 360) — seule la liste articles grandit
	// (kBindAll). Les deux panneaux du bas (preview gauche, options droite)
	// ont été décalés de +240 et les dropdowns Parution/Section/SsSection
	// passés en kBindLeft|kBindTop / kBindRight|kBindTop pour rester fixes.
