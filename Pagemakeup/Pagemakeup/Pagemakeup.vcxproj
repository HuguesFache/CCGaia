      <ProgramDatabaseFile>$(IntDir)Pagemakeup.pdb</ProgramDatabaseFile>
      <ImportLibrary>$(IntDir)Pagemakeup.lib</ImportLibrary>
    </Link>
    <PostBuildEvent>
      <Command>restore_res.cmd "$(IntDir)"  PMU</Command>
    </PostBuildEvent>
  </ItemDefinitionGroup>
