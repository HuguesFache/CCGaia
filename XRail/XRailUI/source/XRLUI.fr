resource XRLUICommentsPanelWidget (kXRLUICommentsPanelResourceID + index_enUS)
{
	__FILE__,
	__LINE__,
	kXRLUICommentsPanelWidgetID,	// WidgetId
	kPMRsrcID_None,
	kBindNone,
	Frame(0,0,420,260)				// Frame: l, t, r, b
	kTrue, kTrue,					// Visible, Enabled
	kTrue,							// Erase background
	kInterfacePaletteFill,
	kFalse,							// Draw dropshadow
	kXRLUICommentsPanelTitleKey,	// Panel name (used internally; the Window
									// menu entry comes from PanelList altMenu).
	{
		// "Not connected" / "no Gaia page" overlays — invisible by default,
		// toggled by XRLUICommentsPanelObserver::UpdateLoginState() based on
		// the XRail login string and the front document's page-slug ID.
		// Mirrors the pattern used by the Photos liées palette in XPage UI.
		StaticTextWidget
		(
			kXRLUICommentsLoginPromptTextWidgetID,
			kSysStaticTextPMRsrcId,
			kBindNone,
			Frame(20, 60, 400, 120)
			kFalse, kTrue,					// Visible (off — observer decides)
			kAlignCenter, kEllipsizeEnd, kTrue,
			kXRLUICommentsLoginPromptTextKey,
			0,
		),
		ButtonWidget
		(
			kXRLUICommentsLoginPromptButtonWidgetID,
			kSysButtonPMRsrcId,
			kBindNone,
			Frame(150, 135, 270, 160)
			kFalse, kTrue,
			kXRLUICommentsLoginPromptButtonKey,
		),
		StaticTextWidget
		(
			kXRLUICommentsNoGaiaPageTextWidgetID,
			kSysStaticTextPMRsrcId,
			kBindNone,
			Frame(20, 90, 400, 150)
			kFalse, kTrue,
			kAlignCenter, kEllipsizeEnd, kTrue,
			kXRLUICommentsNoGaiaPageTextKey,
			0,
		),
		// Header row — fixed-position labels above the tree view. Column
		// widths must match the cells declared in XRLUICommentsNodeWidget
		// below; if you change one, change the other.
		StaticTextWidget
		(
			kXRLUICommentsHeaderCheckWidgetID,
			kSysStaticTextPMRsrcId,
			kBindLeft | kBindTop,
			Frame(8, 4, 38, 20)
			kTrue, kTrue,
			kAlignCenter, kEllipsizeEnd, kTrue,
			kXRLUICommentsColCheckKey,
			0,
		),
		StaticTextWidget
		(
			kXRLUICommentsHeaderDateWidgetID,
			kSysStaticTextPMRsrcId,
			kBindLeft | kBindTop,
			Frame(40, 4, 130, 20)
			kTrue, kTrue,
			kAlignCenter, kEllipsizeEnd, kTrue,
			kXRLUICommentsColDateKey,
			0,
		),
		StaticTextWidget
		(
			kXRLUICommentsHeaderTextWidgetID,
			kSysStaticTextPMRsrcId,
			kBindLeft | kBindRight | kBindTop,
			Frame(132, 4, 290, 20)
			kTrue, kTrue,
			kAlignCenter, kEllipsizeEnd, kTrue,
			kXRLUICommentsColTextKey,
			0,
		),
		StaticTextWidget
		(
			kXRLUICommentsHeaderUserWidgetID,
			kSysStaticTextPMRsrcId,
			kBindRight | kBindTop,
			Frame(292, 4, 410, 20)
			kTrue, kTrue,
			kAlignCenter, kEllipsizeEnd, kTrue,
			kXRLUICommentsColUserKey,
			0,
		),
		// Container with border holds the tree view — gives a flat 1px line
		// matching the screenshot. Bottom margin reserved for the refresh
		// button.
		GenericPanelWithBorderWidget
		(
			0,
			kPMRsrcID_None,
			kBindAll,
			Frame(4, 22, 416, 222)
			kTrue, kTrue,
			"",
			{
				XRLUICommentsViewWidget
				(
					kXRLUICommentsViewWidgetID,
					kPMRsrcID_None,
					kBindAll,
					Frame(2, 2, 410, 218)
					kTrue, kTrue,
					kTrue,					// Erase before draw
					kInterfacePaletteFill,
					"",
					kFalse,					// Display root node
					kFalse,					// Use H scroll bar
					kTrue,					// Use V scroll bar
					20, 20, 20, 20,
					1,						// Single selection
					kFalse,
					kFalse,
					{
					}
				),
			}
		),
		// Refresh button — anchored bottom-left. The bottom-right corner is
		// reserved for the OS resize grip that would otherwise mask the icon.
		// Triggers the panel observer's RefreshList() on click via
		// kTrueStateMessage.
		RollOverIconButtonWidget
		(
			kXRLUICommentsRefreshButtonWidgetID,
			kXRLUICommentsRefreshIconResID,
			kXRLUIPluginID,
			kBindLeft | kBindBottom,
			Frame(8, 226, 32, 250)
			kTrue, kTrue,
			kADBEIconSuiteButtonType,
		),
		// "Show all comments on the page" checkbox — sits next to the refresh
		// icon. When ticked, the panel observer registers a spread adornment
		// that paints a marker at each comment's (X%, Y%) position.
		CheckBoxWidget
		(
			kXRLUICommentsShowAllCheckWidgetID,
			kSysCheckBoxPMRsrcId,
			kBindLeft | kBindBottom,
			Frame(46, 232, 246, 252)
			kTrue, kTrue,
			kAlignLeft,
			kXRLUICommentsShowAllKey,
		),
	}
};

