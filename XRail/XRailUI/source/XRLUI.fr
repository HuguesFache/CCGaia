//============================================================================
// Commentaires palette resources.
// Window > Gaia > Commentaires. Skeleton mirrors the Photos liées palette
// pattern from XPage UI: panel widget hosts a TreeView + a refresh button;
// each row is a TreeNodeWidget with 4 cells (check / date / comment / user).
//============================================================================

resource PNGA(kXRLUICommentsRefreshIconResID) "story_update.png"

/* PanelList — registers the palette with the panel manager. The empty
   panelName + non-empty altMenu pattern places the menu entry only under
   Window > Gaia (no duplicate at the root of Window). Same convention used
   by the XPage palettes for Window > Gaia > XDA / XPage / Photos liées /
   Assemblages.
*/
resource PanelList (kSDKDefPanelResourceID)
{
	{
		kXRLUICommentsPanelResourceID,			// Panel resource id
		kXRLUIPluginID,							// Owning plug-in
		kIsResizable,
		kXRLUICommentsPanelWidgetActionID,		// Show/hide action id
		"",										// Empty panelName — see altMenu.
		"Main:&Window:&Gaia:&Commentaires",		// Window > Gaia > Commentaires
		0.0,
		0, 0,
		c_Panel,
	}
};

